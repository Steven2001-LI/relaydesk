# 复制为 .env 并填入你的 DeepSeek key
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 可选：默认即 DeepSeek 官方地址与模型，一般不用改
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ── RAG：硅基流动 SiliconFlow（embedding + rerank）──────────────────────────
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
SILICONFLOW_RERANK_MODEL=BAAI/bge-reranker-v2-m3

# ── 阶段 4：持久化（SqliteSaver）────────────────────────────────────────────
# 检查点后端：memory（默认，内存版重启即丢）| sqlite（落 data/checkpoints.sqlite，重启仍记得上文）
CS_CHECKPOINT=memory

# ── 阶段 4：LangSmith 可观测 + 端到端评测（需注册账号拿 key）─────────────────
# 设好下面三个后，LangGraph 会**自动**把每次 invoke 的节点级 trace 上传到 LangSmith 云端，
# 无需改任何图代码。trace 数据会上传到 LangChain 云，按需开启。
# 本地端到端评测（langgraph_cs.eval.answer_eval）不依赖这些，缺 key 也能跑。
#
# 默认关闭（false）：直接复制本模板的人即便没改下面的占位 key 也不会触发 tracing，
#   避免带着假 LANGSMITH_API_KEY 去上传 trace 而报错/无效上传。
# 要用 LangSmith 时：把 LANGSMITH_TRACING 改成 true，并把 LANGSMITH_API_KEY 换成
#   你在 LangSmith 注册拿到的**真实** key（占位符不会生效）。
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=echomind-langgraph
